# This is the configuration file for Ghostty.

theme = Dracula

font-family = "D2Coding, DejaVuSansM Nerd Font Mono"
font-size = 16

window-height = 50
window-width = 200

split-divider-color = #ff6600

scrollback-limit = 99999

keybind = shift+enter=text:\x1b\r

copy-on-select = true

confirm-close-surface = false

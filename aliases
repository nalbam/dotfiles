# Local development servers
# Registry of servers started by ss(): one "port<TAB>type<TAB>path" per line
DEV_SERVERS="$HOME/.toast/servers"
_port_kill() {
  # Kill whatever listens on a port; 0 if killed, 1 if nothing found
  local port="$1"
  local pids=$(lsof -ti:"$port" -sTCP:LISTEN 2>/dev/null | sort -u)
  [ -z "$pids" ] && return 1
  echo "$pids" | while read pid; do
    local cmd=$(ps -p "$pid" -o comm= 2>/dev/null)
    kill $pid 2>/dev/null && echo "  Killed $cmd (PID $pid) on port $port"
  done
  return 0
}
_server_del() {
  [ -f "$DEV_SERVERS" ] || return 0
  awk -F'\t' -v p="$1" '$1 != p' "$DEV_SERVERS" > "$DEV_SERVERS.tmp" 2>/dev/null
  mv "$DEV_SERVERS.tmp" "$DEV_SERVERS"
}
_server_add() {
  mkdir -p "$(dirname "$DEV_SERVERS")"
  _server_del "$1"
  printf '%s\t%s\t%s\n' "$1" "$2" "$3" >> "$DEV_SERVERS"
}
ss() {
  # Server start - node dev (package.json) or python http.server
  if [ -f "package.json" ]; then
    local port="${1:-3000}"
    _port_kill "$port" > /dev/null 2>&1
    _server_add "$port" "node" "$(pwd)"
    echo "Starting node dev server on port $port..."
    case "$(np)" in
      pnpm) PORT="$port" pnpm dev ;;
      yarn) PORT="$port" yarn dev ;;
      *) PORT="$port" npm run dev ;;
    esac
    _server_del "$port"
  else
    local port="${1:-8000}"
    local dir="${2:-docs}"
    local abs_dir=$(cd "$dir" 2>/dev/null && pwd)
    if [ -z "$abs_dir" ]; then
      echo "Directory '$dir' not found"
      return 1
    fi
    _port_kill "$port" > /dev/null 2>&1
    python3 -m http.server "$port" --directory "$abs_dir" > /dev/null 2>&1 & disown
    _server_add "$port" "python" "$abs_dir"
    echo "Serving $abs_dir at http://localhost:$port"
  fi
}
sl() {
  # Server list - show servers started by ss(), pruning dead ones
  [ -f "$DEV_SERVERS" ] || { echo "No servers running"; return 0; }
  local tmp="$DEV_SERVERS.tmp"
  : > "$tmp"
  local found=""
  while IFS="$(printf '\t')" read -r port type dir; do
    [ -z "$port" ] && continue
    local pid=$(lsof -ti:"$port" -sTCP:LISTEN 2>/dev/null | head -1)
    if [ -n "$pid" ]; then
      local cmd=$(ps -p "$pid" -o comm= 2>/dev/null)
      [ -z "$found" ] && echo "Local servers:"
      echo "  [$type] $cmd (PID $pid) on port $port  $dir"
      printf '%s\t%s\t%s\n' "$port" "$type" "$dir" >> "$tmp"
      found="1"
    fi
  done < "$DEV_SERVERS"
  mv "$tmp" "$DEV_SERVERS"
  [ -z "$found" ] && echo "No servers running"
}
sk() {
  # Server kill - kill a tracked port, or all servers started by ss()
  if [ -z "$1" ]; then
    echo "Usage: sk <port|all>"
    echo "  sk <port>  - Kill server on a specific port"
    echo "  sk a|all   - Kill all servers started by ss()"
    return 1
  fi
  case "$1" in
    a|all)
      [ -f "$DEV_SERVERS" ] || { echo "No servers running"; return 0; }
      local any=""
      while IFS="$(printf '\t')" read -r port type dir; do
        [ -z "$port" ] && continue
        _port_kill "$port" && any="1"
      done < "$DEV_SERVERS"
      : > "$DEV_SERVERS"
      [ -z "$any" ] && echo "No servers running"
      ;;
    *)
      if _port_kill "$1"; then
        _server_del "$1"
      else
        echo "No process found on port $1"
      fi
      ;;
  esac
}


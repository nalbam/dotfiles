# Node.js / JavaScript / TypeScript
# Detect package manager: package.json "packageManager" field, else lock file
np() {
  local pm=""
  if [ -f "package.json" ]; then
    pm=$(node -p "(require('./package.json').packageManager || '').split('@')[0]" 2>/dev/null)
  fi
  case "$pm" in
    pnpm | npm | yarn) echo "$pm" ;;
    *)
      if [ -f "pnpm-lock.yaml" ]; then
        echo "pnpm"
      elif [ -f "yarn.lock" ]; then
        echo "yarn"
      else
        echo "npm"
      fi
      ;;
  esac
}
nn() {
  case "$(np)" in
    pnpm)
      echo "Cleaning and reinstalling with pnpm..."
      rm -rf node_modules pnpm-lock.yaml .next && pnpm install
      ;;
    yarn)
      echo "Cleaning and reinstalling with yarn..."
      rm -rf node_modules yarn.lock dist && yarn install
      ;;
    *)
      echo "Cleaning and reinstalling with npm..."
      rm -rf node_modules package-lock.json dist && npm install
      ;;
  esac
}
nb() {
  case "$(np)" in
    pnpm) pnpm build ;;
    yarn) yarn build ;;
    *) npm run build ;;
  esac
}


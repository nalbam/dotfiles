# tmux
tm() {
  # Interactive tmux session manager; pass args to tmux directly if provided
  if [ $# -gt 0 ]; then
    tmux "$@"
    return
  fi

  local default_name
  default_name=$(basename "$PWD")

  local sessions
  sessions=$(tmux ls 2>/dev/null)

  if command -v fzf &>/dev/null; then
    local options
    if [ -n "$sessions" ]; then
      options="$sessions"$'\n'"[+ new session]"$'\n'"[x kill session]"
    else
      options="[+ new session]"
    fi

    local selected
    selected=$(echo "$options" | fzf \
      --prompt="tmux > " \
      --height=40% \
      --layout=reverse \
      --border \
      --no-sort)

    [ -z "$selected" ] && return

    case "$selected" in
      "[+ new session]")
        printf "Session name [%s]: " "$default_name"
        read -r name
        tmux new -s "${name:-$default_name}"
        ;;
      "[x kill session]")
        local kill_sel
        kill_sel=$(tmux ls 2>/dev/null | fzf \
          --prompt="kill > " \
          --height=40% \
          --layout=reverse \
          --border \
          --header="Select session to kill" \
          --no-sort)
        if [ -n "$kill_sel" ]; then
          local kill_name
          kill_name=$(echo "$kill_sel" | awk -F: '{print $1}')
          tmux kill-session -t "$kill_name" && echo "Killed: $kill_name"
        fi
        ;;
      *)
        local session_name
        session_name=$(echo "$selected" | awk -F: '{print $1}')
        tmux attach -t "$session_name"
        ;;
    esac
  else
    # Fallback: numbered menu without fzf
    if [ -z "$sessions" ]; then
      printf "No tmux sessions. Session name [%s]: " "$default_name"
      read -r name
      tmux new -s "${name:-$default_name}"
      return
    fi

    echo "tmux sessions:"
    local i=1
    local line
    while IFS= read -r line; do
      printf "  %d) %s\n" $i "$(echo "$line" | awk -F: '{print $1}')"
      i=$((i+1))
    done <<< "$sessions"
    printf "  n) new   k) kill   q) quit\nSelect: "
    read -r choice

    case "$choice" in
      n)
        printf "Session name [%s]: " "$default_name"
        read -r name
        tmux new -s "${name:-$default_name}"
        ;;
      k)
        printf "Kill session name: "
        read -r name
        [ -n "$name" ] && tmux kill-session -t "$name" && echo "Killed: $name"
        ;;
      q|"") return ;;
      *)
        local target
        target=$(echo "$sessions" | sed -n "${choice}p" | awk -F: '{print $1}')
        [ -n "$target" ] && tmux attach -t "$target" || echo "Invalid selection"
        ;;
    esac
  fi
}

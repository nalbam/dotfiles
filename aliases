# Node.js / JavaScript / TypeScript
nn() {
  if [ -f "pnpm-lock.yaml" ]; then
    echo "Found pnpm-lock.yaml, cleaning and reinstalling with pnpm..."
    rm -rf node_modules pnpm-lock.yaml .next && pnpm install
  elif [ -f "package-lock.json" ]; then
    echo "Found package-lock.json, cleaning and reinstalling with npm..."
    rm -rf node_modules package-lock.json dist && npm install
  else
    echo "No lock file found, installing with npm..."
    npm install
  fi
}
nb() {
  if [ -f "pnpm-lock.yaml" ]; then
    pnpm build
  elif [ -f "package-lock.json" ]; then
    npm run build
  else
    npm run build
  fi
}
nk() {
  local pids=$(lsof -i -P -n | grep LISTEN | grep -E '[ *]:3[0-9]{3}(\s|$)' | awk '{print $2}' | sort -u)
  if [ -n "$pids" ]; then
    echo "Killing dev servers on port 3000-3999..."
    echo "$pids" | while read pid; do
      local info=$(lsof -i -P -n | grep LISTEN | grep "^[^ ]*[ ]*$pid" | head -1)
      local port=$(echo "$info" | awk '{print $(NF-1)}' | awk -F: '{print $NF}')
      local cmd=$(echo "$info" | awk '{print $1}')
      kill $pid 2>/dev/null && echo "  Killed $cmd (PID $pid) on port $port"
    done
  fi
}
nd() {
  nk
  if [ -f "pnpm-lock.yaml" ]; then
    pnpm dev
  elif [ -f "package-lock.json" ]; then
    npm run dev
  else
    npm run dev
  fi
}


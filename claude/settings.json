{
  "cleanupPeriodDays": 3650,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "1"
  },
  "model": "claude-fable-5[1m]",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Skill(*)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(chmod -R 777 /:*)",
      "Bash(chown -R * /:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(dd if=/dev/zero:*)",
      "Bash(fdisk:*)",
      "Bash(gdisk:*)",
      "Bash(halt:*)",
      "Bash(init 0:*)",
      "Bash(init 6:*)",
      "Bash(mkfs:*)",
      "Bash(parted:*)",
      "Bash(poweroff:*)",
      "Bash(reboot:*)",
      "Bash(rm -rf $HOME/*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(shutdown:*)",
      "Bash(sudo rm -rf:*)",
      "Bash(systemctl disable:*)",
      "Bash(systemctl halt:*)",
      "Bash(systemctl poweroff:*)",
      "Bash(systemctl reboot:*)",
      "Bash(systemctl stop:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/vibemon.py",
            "timeout": 10,
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/memory-sync.sh start",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/vibemon.py",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/vibemon.py",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/vibemon.py",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/vibemon.py",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/vibemon.py",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/vibemon.py",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/vibemon.py",
            "timeout": 10,
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/memory-sync.sh end",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/vibemon.py",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "chrome-devtools-mcp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "humanize-korean@im-not-ai": true,
    "karrot-self-review@karrot-hr": true,
    "linear@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "im-not-ai": {
      "source": {
        "source": "github",
        "repo": "epoko77-ai/im-not-ai"
      }
    },
    "karrot-hr": {
      "source": {
        "source": "git",
        "url": "git@github.com:karrot-emu/karrot-self-review.git"
      }
    }
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "theme": "auto"
}
